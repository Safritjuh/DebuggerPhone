<Window x:Class="WindowsSipPhone.UI.Dialogs.SipMessageDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIP Message Details" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9FA">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Background="#34495E" Margin="-15,-15,-15,15">
            <StackPanel Orientation="Horizontal" Margin="15,10">
                <TextBlock x:Name="DirectionIcon" Text="📤" FontSize="18" Margin="0,0,10,0"/>
                <TextBlock Text="SIP Message Details" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold"/>
            </StackPanel>
        </Grid>
        
        <!-- Content -->
        <TabControl Grid.Row="1" Margin="0,0,0,15">
            <!-- Raw Message Tab -->
            <TabItem Header="📄 Raw Message">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Message Info -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Type:" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="MessageTypeText" Margin="0,0,15,0"/>
                        <TextBlock Text="Time:" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="TimestampText" Margin="0,0,15,0"/>
                        <TextBlock Text="Direction:" FontWeight="Bold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="DirectionText" Margin="0,0,15,0"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1">
                        <TextBox x:Name="RawMessageTextBox" 
                                 FontFamily="Consolas" 
                                 FontSize="12"
                                 IsReadOnly="True"
                                 Background="#FAFAFA"
                                 Padding="10"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- Parsed Headers Tab -->
            <TabItem Header="📋 Parsed Headers">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="SIP Headers with Descriptions" 
                                   FontWeight="Bold" 
                                   Margin="0,0,15,10"/>
                        <TextBlock x:Name="CallIdText" 
                                   FontStyle="Italic"
                                   Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <ListView Grid.Row="1" x:Name="HeadersListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Header" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Value" Width="300" DisplayMemberBinding="{Binding Value}"/>
                                <GridViewColumn Header="Description" Width="400" DisplayMemberBinding="{Binding Description}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
            
            <!-- Message Analysis Tab -->
            <TabItem Header="🔍 Analysis">
                <ScrollViewer>
                    <StackPanel Margin="0,0,0,15">
                        <!-- Message Info -->
                        <GroupBox Header="📊 Message Information" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Direction:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AnalysisDirectionText" Margin="5"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Method/Response:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MethodText" Margin="5"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Message Size:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SizeText" Margin="5"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Line Count:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LineCountText" Margin="5"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Protocol Version:" FontWeight="Bold" Margin="5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ProtocolText" Margin="5"/>
                            </Grid>
                        </GroupBox>
                        
                        <!-- Routing Info -->
                        <GroupBox Header="🌐 Routing Information" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="RoutingInfoText" TextWrapping="Wrap" Margin="5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- Message Interpretation -->
                        <GroupBox Header="💡 Message Interpretation">
                            <TextBlock x:Name="InterpretationText" 
                                       TextWrapping="Wrap" 
                                       Margin="5"
                                       Background="#E8F5E8"
                                       Padding="10"/>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Related Messages Tab -->
            <TabItem Header="🔗 Related">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="Messages related to this call/transaction" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    
                    <ListView Grid.Row="1" x:Name="RelatedMessagesListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Direction" Width="80" DisplayMemberBinding="{Binding Direction}"/>
                                <GridViewColumn Header="Method" Width="100" DisplayMemberBinding="{Binding Method}"/>
                                <GridViewColumn Header="Summary" Width="500" DisplayMemberBinding="{Binding Summary}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="📋 Copy Raw" Click="CopyRaw_Click" 
                    Background="#3498DB" Foreground="White" 
                    Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="💾 Export" Click="Export_Click" 
                    Background="#27AE60" Foreground="White" 
                    Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="❌ Close" Click="Close_Click" 
                    Background="#E74C3C" Foreground="White" 
                    Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>
