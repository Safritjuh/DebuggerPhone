<UserControl x:Class="WindowsSipPhone.UI.Pages.AudioSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#E67E22" Padding="20,15,20,15">
            <StackPanel>
                <TextBlock Text="🔊 Audio Settings" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="Configure audio devices, codecs, and sound preferences" 
                          FontSize="12" 
                          Foreground="#F8E6D3" 
                          Margin="0,3,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                
                <!-- Audio Input (Microphone) Section -->
                <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎤 Microphone (Audio Input)" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,10"/>
                          <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="Device:" 
                                       VerticalAlignment="Center" 
                                       FontWeight="Medium"/>
                            
                            <ComboBox Grid.Column="1" 
                                      x:Name="MicrophoneComboBox" 
                                      Margin="10,0"
                                      Padding="8"
                                      SelectionChanged="MicrophoneComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎤" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
  
                        </Grid>
                        
                        <!-- Microphone Level Meter -->
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Input Level:" FontSize="12" Foreground="#666"/>
                            <Border Background="#E0E0E0" CornerRadius="3" Height="8" Margin="0,3,0,0">
                                <Border x:Name="MicrophoneLevelBar" 
                                        Background="#4CAF50" 
                                        CornerRadius="3" 
                                        HorizontalAlignment="Left" 
                                        Width="0"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- Microphone Controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <CheckBox x:Name="MicrophoneMuteCheckBox" 
                                      Content="🔇 Mute Microphone" 
                                      Checked="MicrophoneMute_Changed" 
                                      Unchecked="MicrophoneMute_Changed"/>
                            <Slider x:Name="MicrophoneVolumeSlider" 
                                    Width="150" 
                                    Minimum="0" 
                                    Maximum="100" 
                                    Value="80" 
                                    Margin="20,0,10,0"
                                    ValueChanged="MicrophoneVolume_Changed"/>
                            <TextBlock x:Name="MicrophoneVolumeLabel" 
                                       Text="80%" 
                                       VerticalAlignment="Center" 
                                       MinWidth="35"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Audio Output (Speaker) Section -->
                <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🔊 Speaker (Audio Output)" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,10"/>
                          <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="Device:" 
                                       VerticalAlignment="Center" 
                                       FontWeight="Medium"/>
                            
                            <ComboBox Grid.Column="1" 
                                      x:Name="SpeakerComboBox" 
                                      Margin="10,0"
                                      Padding="8"
                                      SelectionChanged="SpeakerComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔊" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        
                        <!-- Speaker Level Meter -->
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Output Level:" FontSize="12" Foreground="#666"/>
                            <Border Background="#E0E0E0" CornerRadius="3" Height="8" Margin="0,3,0,0">
                                <Border x:Name="SpeakerLevelBar" 
                                        Background="#2196F3" 
                                        CornerRadius="3" 
                                        HorizontalAlignment="Left" 
                                        Width="0"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- Speaker Controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <CheckBox x:Name="SpeakerMuteCheckBox" 
                                      Content="🔇 Mute Speaker" 
                                      Checked="SpeakerMute_Changed" 
                                      Unchecked="SpeakerMute_Changed"/>
                            <Slider x:Name="SpeakerVolumeSlider" 
                                    Width="150" 
                                    Minimum="0" 
                                    Maximum="100" 
                                    Value="80" 
                                    Margin="20,0,10,0"
                                    ValueChanged="SpeakerVolume_Changed"/>
                            <TextBlock x:Name="SpeakerVolumeLabel" 
                                       Text="80%" 
                                       VerticalAlignment="Center" 
                                       MinWidth="35"/>
                        </StackPanel>
                    </StackPanel>                </Border>

                <!-- Microphone Test Section -->
                <Border Background="#E8F5E8" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🎤 Microphone Test" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Record a short audio clip and play it back to test your microphone and speaker settings." 
                                   FontSize="12" 
                                   Foreground="#666" 
                                   Margin="0,0,0,15" 
                                   TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button x:Name="StartRecordingButton" 
                                    Content="🔴 Start Recording" 
                                    Click="StartRecording_Click"
                                    Background="#E53E3E" 
                                    Foreground="White" 
                                    Padding="15,8" 
                                    Margin="0,0,10,0"/>
                            <Button x:Name="StopRecordingButton" 
                                    Content="⏹️ Stop Recording" 
                                    Click="StopRecording_Click"
                                    Background="#718096" 
                                    Foreground="White" 
                                    Padding="15,8" 
                                    Margin="0,0,10,0"
                                    IsEnabled="False"/>
                            <Button x:Name="PlayBackButton" 
                                    Content="▶️ Play Back" 
                                    Click="PlayBack_Click"
                                    Background="#38A169" 
                                    Foreground="White" 
                                    Padding="15,8"
                                    IsEnabled="False"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="MicrophoneTestStatusLabel" 
                                   Text="Click 'Start Recording' to record a 3-second audio clip" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,10" 
                                   FontStyle="Italic" 
                                   Foreground="#666"/>
                          <!-- Recording Level Indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="Recording Level: " VerticalAlignment="Center" FontWeight="Medium"/>
                            <ProgressBar x:Name="RecordingLevelBar" 
                                         Width="200" 
                                         Height="15" 
                                         Minimum="0"                                         Maximum="100" 
                                         Value="0"
                                         Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Action Buttons -->
                <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ResetToDefaultsButton" 
                                Content="🔄 Reset to Defaults" 
                                Click="ResetToDefaults_Click"
                                Background="#607D8B" 
                                Foreground="White" 
                                Padding="15,8" 
                                Margin="0,0,10,0"/>
                        <Button x:Name="ApplySettingsButton"
                                Content="✅ Apply Settings" 
                                Click="ApplySettings_Click"
                                Background="#4CAF50" 
                                Foreground="White" 
                                Padding="15,8" 
                                IsDefault="True"/>
                    </StackPanel>
                </Border>
                  </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
