<UserControl x:Class="WindowsSipPhone.Controls.AudioDeviceHealthControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Border Style="{StaticResource ModernCardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,8">
        <StackPanel>
            <TextBlock Text="🎧 Audio Device Health" 
                      Style="{StaticResource SubheaderTextStyle}"
                      Margin="0,0,0,16"/>
            
            <!-- Input Device Status -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🎤 Input Device" 
                              FontWeight="Medium"
                              Margin="0,0,0,4"/>
                    <TextBlock x:Name="InputDeviceText"
                              Text="None selected"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              Margin="0,0,0,2"/>
                    <TextBlock x:Name="InputStatusText"
                              Text="❓ Not tested"
                              FontSize="12"/>
                </StackPanel>
                
                <Button x:Name="TestInputButton"
                       Grid.Column="1"
                       Content="🔄 Test"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="TestInputButton_Click"/>
            </Grid>
            
            <!-- Output Device Status -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔊 Output Device" 
                              FontWeight="Medium"
                              Margin="0,0,0,4"/>
                    <TextBlock x:Name="OutputDeviceText"
                              Text="None selected"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              Margin="0,0,0,2"/>
                    <TextBlock x:Name="OutputStatusText"
                              Text="❓ Not tested"
                              FontSize="12"/>
                </StackPanel>
                
                <Button x:Name="TestOutputButton"
                       Grid.Column="1"
                       Content="🔄 Test"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="TestOutputButton_Click"/>
            </Grid>
            
            <!-- Device Statistics -->
            <Border Background="{StaticResource DividerBrush}" 
                   CornerRadius="4" 
                   Padding="12"
                   Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sample Rate" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="12"
                                  FontWeight="Medium"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="SampleRateText"
                                  Text="Unknown"
                                  FontSize="14"
                                  FontWeight="Medium"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Latency" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="12"
                                  FontWeight="Medium"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="LatencyText"
                                  Text="Unknown"
                                  FontSize="14"
                                  FontWeight="Medium"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Buffer Size" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="12"
                                  FontWeight="Medium"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="BufferSizeText"
                                  Text="Unknown"
                                  FontSize="14"
                                  FontWeight="Medium"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Audio Quality Status -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Audio Quality Monitor" 
                              FontWeight="Medium"
                              Margin="0,0,0,4"/>
                    <TextBlock x:Name="QualityStatusText"
                              Text="⏸️ Disabled"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"/>
                </StackPanel>
                
                <ToggleButton x:Name="QualityMonitorToggle"
                             Grid.Column="1"
                             Style="{StaticResource ModernToggleButtonStyle}"
                             Checked="QualityMonitorToggle_Checked"
                             Unchecked="QualityMonitorToggle_Unchecked"/>
            </Grid>
            
            <!-- Audio Levels -->
            <StackPanel x:Name="AudioLevelsPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <TextBlock Text="Real-time Audio Levels" 
                          FontWeight="Medium"
                          Margin="0,0,0,8"/>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Input Level -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Input:" FontSize="12" VerticalAlignment="Center"/>
                        <ProgressBar x:Name="InputLevelBar" 
                                   Grid.Column="1" 
                                   Height="16" 
                                   Margin="8,0"
                                   Minimum="0" 
                                   Maximum="100"/>
                        <TextBlock x:Name="InputLevelText" 
                                  Grid.Column="2" 
                                  Text="0%" 
                                  FontSize="12" 
                                  VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Output Level -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Output:" FontSize="12" VerticalAlignment="Center"/>
                        <ProgressBar x:Name="OutputLevelBar" 
                                   Grid.Column="1" 
                                   Height="16" 
                                   Margin="8,0"
                                   Minimum="0" 
                                   Maximum="100"/>
                        <TextBlock x:Name="OutputLevelText" 
                                  Grid.Column="2" 
                                  Text="0%" 
                                  FontSize="12" 
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </StackPanel>
            
            <!-- Error Messages -->
            <TextBlock x:Name="ErrorMessageText"
                      Text=""
                      Foreground="{StaticResource ErrorBrush}"
                      FontSize="12"
                      FontWeight="Medium"
                      Visibility="Collapsed"
                      TextWrapping="Wrap"
                      Margin="0,8,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
