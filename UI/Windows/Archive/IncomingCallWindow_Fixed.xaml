<Window x:Class="WindowsSipPhone.IncomingCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Incoming Call" Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    
    <Window.Resources>
        <!-- Circular Button Style -->
        <Style x:Key="CircularButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" 
                                    Stroke="{TemplateBinding BorderBrush}"
                                    StrokeThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Call Action Button Style -->
        <Style x:Key="CallButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Background="#2C3E50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Incoming Call Icon -->
        <Viewbox Grid.Row="0" Width="64" Height="64" 
                 HorizontalAlignment="Center" 
                 Margin="0,25,0,15">
            <Path Data="M6.62,10.79C6.24,10.41 6.24,9.78 6.62,9.4L10.89,5.13C11.3,4.72 11.93,4.72 12.34,5.13L16.61,9.4C17,9.78 17,10.41 16.61,10.79L12.34,15.06C11.93,15.47 11.3,15.47 10.89,15.06L6.62,10.79Z M15.5,6C17.71,6 19.5,7.79 19.5,10V14C19.5,16.21 17.71,18 15.5,18H8.5C6.29,18 4.5,16.21 4.5,14V10C4.5,7.79 6.29,6 8.5,6H15.5M7.5,7.5V16.5C7.5,17.33 8.17,18 9,18H15C15.83,18 16.5,17.33 16.5,16.5V7.5C16.5,6.67 15.83,6 15,6H9C8.17,6 7.5,6.67 7.5,7.5Z" 
                  Fill="White" 
                  Stretch="Uniform"/>
        </Viewbox>
        
        <!-- Call Information -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="Incoming Call" 
                       FontSize="16" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Foreground="#E8F5E8" 
                       Margin="0,0,0,15"/>
            
            <!-- Large, prominent caller name -->
            <TextBlock x:Name="CallerNameText" 
                       FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Foreground="White" 
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"
                       MaxWidth="350"
                       TextAlignment="Center">
                <TextBlock.Text>
                    <Binding Path="CallerName" FallbackValue="Unknown Caller"/>
                </TextBlock.Text>
            </TextBlock>
            
            <!-- Caller number in smaller text -->
            <TextBlock x:Name="CallerNumberText" 
                       FontSize="16" FontWeight="Medium" 
                       HorizontalAlignment="Center" 
                       Foreground="#BDC3C7" 
                       Margin="0,0,0,15"
                       TextAlignment="Center">
                <TextBlock.Text>
                    <Binding Path="CallerNumber" FallbackValue="Unknown Number"/>
                </TextBlock.Text>
            </TextBlock>
            
            <!-- Call duration -->
            <TextBlock x:Name="CallDurationText" 
                       Text="{Binding Duration}" 
                       FontSize="14" 
                       HorizontalAlignment="Center" 
                       Foreground="#95A5A6"
                       TextAlignment="Center"/>
        </StackPanel>
        
        <!-- Call Actions -->
        <Grid Grid.Row="2" Margin="40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Accept Button - Green Circle with Lifted Handset -->
            <Button Grid.Column="0" x:Name="AcceptButton"
                    Style="{StaticResource CircularButtonStyle}"
                    Background="#27AE60"
                    HorizontalAlignment="Center"
                    Click="Accept_Click">
                <Path Data="M6.62,10.79C6.24,10.41 6.24,9.78 6.62,9.4L10.89,5.13C11.3,4.72 11.93,4.72 12.34,5.13L16.61,9.4C17,9.78 17,10.41 16.61,10.79L12.34,15.06C11.93,15.47 11.3,15.47 10.89,15.06L6.62,10.79Z M15.5,6C17.71,6 19.5,7.79 19.5,10V14C19.5,16.21 17.71,18 15.5,18H8.5C6.29,18 4.5,16.21 4.5,14V10C4.5,7.79 6.29,6 8.5,6H15.5M7.5,7.5V16.5C7.5,17.33 8.17,18 9,18H15C15.83,18 16.5,17.33 16.5,16.5V7.5C16.5,6.67 15.83,6 15,6H9C8.17,6 7.5,6.67 7.5,7.5Z" 
                      Fill="White" 
                      Stretch="Uniform" 
                      Width="36" 
                      Height="36"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform Angle="-15"/>
                    </Path.RenderTransform>
                </Path>
            </Button>
                    
            <!-- Decline Button - Red Circle with Horizontal Handset -->
            <Button Grid.Column="2" x:Name="DeclineButton"
                    Style="{StaticResource CircularButtonStyle}"
                    Background="#E74C3C"
                    HorizontalAlignment="Center"
                    Click="Decline_Click">
                <Path Data="M20,15.5C20.11,15.5 20.2,15.59 20.2,15.7V18.3C20.2,18.41 20.11,18.5 20,18.5H4C3.89,18.5 3.8,18.41 3.8,18.3V15.7C3.8,15.59 3.89,15.5 4,15.5H7V13C7,11.9 7.9,11 9,11H15C16.1,11 17,11.9 17,13V15.5H20M9,13V15.5H15V13H9Z" 
                      Fill="White" 
                      Stretch="Uniform" 
                      Width="36" 
                      Height="24"/>
            </Button>
        </Grid>
        
        <!-- Additional Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="MuteButton"
                    Style="{StaticResource CallButtonStyle}"
                    Background="#95A5A6"
                    FontSize="12"
                    Padding="15,5"
                    Click="Mute_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,16H19M16.5,12C16.5,12 18,10.5 18,9C18,7.5 16.5,6 16.5,6L17.5,5C17.5,5 19.5,7 19.5,9C19.5,11 17.5,13 17.5,13L16.5,12Z" 
                          Fill="White" 
                          Width="14" 
                          Height="14" 
                          Stretch="Uniform" 
                          Margin="0,0,5,0"/>
                    <TextBlock Text="Mute" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
