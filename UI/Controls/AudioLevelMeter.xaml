<UserControl x:Class="WindowsSipPhone.UI.Controls.AudioLevelMeter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Unloaded="UserControl_Unloaded">
    
    <Border Style="{StaticResource ModernCardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,8">
        <StackPanel>
            <TextBlock Text="🎤 Audio Levels" 
                      Style="{StaticResource SubheaderTextStyle}"
                      Margin="0,0,0,16"/>
            
            <!-- Input Level Meter -->
            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Input Label -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                          Text="🎤 Input:" 
                          Foreground="{StaticResource TextBrush}"
                          FontSize="12"
                          FontWeight="Medium"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>
                
                <!-- Input Meter Background -->
                <Border x:Name="InputMeterBackground"
                       Grid.Row="0" Grid.Column="1"
                       Height="20"
                       Background="{StaticResource DividerBrush}"
                       BorderBrush="{StaticResource BorderBrush}"
                       BorderThickness="1"
                       CornerRadius="10"
                       Margin="0,0,8,0">
                    
                    <!-- Input Meter Fill -->
                    <Rectangle x:Name="InputMeterFill"
                              Fill="#22C55E"
                              RadiusX="10"
                              RadiusY="10"
                              HorizontalAlignment="Left"
                              Width="0"/>
                </Border>
                
                <!-- Input Level Text -->
                <TextBlock x:Name="InputLevelText"
                          Grid.Row="0" Grid.Column="2"
                          Text="0%"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          FontFamily="Consolas"
                          VerticalAlignment="Center"
                          MinWidth="35"/>
            </Grid>
            
            <!-- Output Level Meter -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Output Label -->
                <TextBlock Grid.Column="0" 
                          Text="🔊 Output:" 
                          Foreground="{StaticResource TextBrush}"
                          FontSize="12"
                          FontWeight="Medium"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>
                
                <!-- Output Meter Background -->
                <Border x:Name="OutputMeterBackground"
                       Grid.Column="1"
                       Height="20"
                       Background="{StaticResource DividerBrush}"
                       BorderBrush="{StaticResource BorderBrush}"
                       BorderThickness="1"
                       CornerRadius="10"
                       Margin="0,0,8,0">
                    
                    <!-- Output Meter Fill -->
                    <Rectangle x:Name="OutputMeterFill"
                              Fill="#22C55E"
                              RadiusX="10"
                              RadiusY="10"
                              HorizontalAlignment="Left"
                              Width="0"/>
                </Border>
                
                <!-- Output Level Text -->
                <TextBlock x:Name="OutputLevelText"
                          Grid.Column="2"
                          Text="0%"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          FontFamily="Consolas"
                          VerticalAlignment="Center"
                          MinWidth="35"/>
            </Grid>
            
            <!-- Test Controls -->
            <Border Background="{StaticResource DividerBrush}" 
                   CornerRadius="4" 
                   Padding="12"
                   Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="🧪 Audio Testing" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              FontWeight="Medium"
                              Margin="0,0,0,8"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0"
                                  Text="Simulate audio levels for testing"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"/>
                        
                        <Button x:Name="TestButton"
                               Grid.Column="1"
                               Content="📈 Test"
                               Style="{StaticResource SecondaryButtonStyle}"
                               FontSize="11"
                               Padding="8,4"
                               Click="TestButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
