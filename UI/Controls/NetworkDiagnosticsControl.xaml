<UserControl x:Class="WindowsSipPhone.UI.Controls.NetworkDiagnosticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Unloaded="UserControl_Unloaded">
    
    <Border Style="{StaticResource ModernCardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,8">
        <StackPanel>
            <TextBlock Text="🔧 Network Diagnostics" 
                      Style="{StaticResource SubheaderTextStyle}"
                      Margin="0,0,0,16"/>
            
            <!-- Control Buttons -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="RunDiagnosticsButton"
                       Grid.Column="0"
                       Content="🔧 Run Diagnostics"
                       Style="{StaticResource ModernButtonStyle}"
                       Click="RunDiagnosticsButton_Click"
                       Margin="0,0,8,0"/>
                
                <Button x:Name="GenerateReportButton"
                       Grid.Column="1"
                       Content="📋 Report"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="GenerateReportButton_Click"/>
            </Grid>
            
            <!-- Status Display -->
            <TextBlock x:Name="DiagnosticsStatus"
                      Text="⏸️ Ready to run diagnostics"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontSize="12"
                      FontWeight="Medium"
                      Margin="0,0,0,16"
                      HorizontalAlignment="Center"/>
            
            <!-- Test Results -->
            <Border Background="{StaticResource DividerBrush}" 
                   CornerRadius="4" 
                   Padding="12">
                <StackPanel>
                    <TextBlock Text="📊 Connectivity Status" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              FontWeight="Medium"
                              Margin="0,0,0,12"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Internet Connectivity -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="🌐 Internet:"
                                  Foreground="{StaticResource TextBrush}"
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="InternetStatus"
                                  Grid.Row="0" Grid.Column="1"
                                  Text="⏸️ Not tested"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        
                        <!-- DNS Resolution -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="🔍 DNS Resolution:"
                                  Foreground="{StaticResource TextBrush}"
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="DnsStatus"
                                  Grid.Row="1" Grid.Column="1"
                                  Text="⏸️ Not tested"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        
                        <!-- SIP Server -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                  Text="📞 SIP Server:"
                                  Foreground="{StaticResource TextBrush}"
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        <TextBlock x:Name="SipServerStatus"
                                  Grid.Row="2" Grid.Column="1"
                                  Text="⏸️ Not tested"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"
                                  Margin="0,0,0,4"/>
                        
                        <!-- Network Interfaces -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                  Text="🔌 Interfaces:"
                                  Foreground="{StaticResource TextBrush}"
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="InterfacesStatus"
                                  Grid.Row="3" Grid.Column="1"
                                  Text="⏸️ Not tested"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Quick Actions -->
            <Border Background="{StaticResource DividerBrush}" 
                   CornerRadius="4" 
                   Padding="12"
                   Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="⚡ Quick Actions" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              FontWeight="Medium"
                              Margin="0,0,0,8"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="📋 Generate detailed diagnostic report for support"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      TextWrapping="Wrap"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="🔄 Continuous monitoring when diagnostics are active"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="📞 Tests connection to SIP server (192.168.1.180)"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      TextWrapping="Wrap"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="🌐 Validates internet and DNS connectivity"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
