<Window x:Class="WindowsSipPhone.IncomingCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Incoming Call" Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Circular Button Style -->
        <Style x:Key="CircularButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" 
                                    x:Name="ButtonEllipse"/>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonEllipse" Property="Opacity" Value="0.9"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonEllipse" Property="Opacity" Value="0.8"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#2C3E50" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Phone Icon -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" 
                       HorizontalAlignment="Center" Margin="0,15,0,20">
                <Path Data="M6.62,10.79C9.24,13.41 14.76,13.41 17.38,10.79L16.79,10.2C14.59,12.4 9.41,12.4 7.21,10.2L6.62,10.79M12,1A7,7 0 0,1 19,8A7,7 0 0,1 12,15A7,7 0 0,1 5,8A7,7 0 0,1 12,1M12,2A6,6 0 0,0 6,8A6,6 0 0,0 12,14A6,6 0 0,0 18,8A6,6 0 0,0 12,2Z" 
                      Fill="#E8F5E8" 
                      Width="24" Height="24" 
                      Stretch="Uniform"
                      Margin="0,0,10,0"/>
                <TextBlock Text="Incoming Call" 
                          FontSize="16" FontWeight="SemiBold" 
                          Foreground="#E8F5E8" 
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Caller Information -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10">
                <!-- Caller Name -->
                <TextBlock x:Name="CallerNameText" 
                          Text="{Binding CallerName, FallbackValue='Unknown Caller'}"
                          FontSize="24" FontWeight="Bold" 
                          HorizontalAlignment="Center" 
                          Foreground="White" 
                          Margin="0,0,0,10"
                          TextWrapping="Wrap"
                          MaxWidth="350"
                          TextAlignment="Center"/>
                
                <!-- Caller Number -->
                <TextBlock x:Name="CallerNumberText" 
                          Text="{Binding CallerNumber, FallbackValue='Unknown Number'}"
                          FontSize="16" FontWeight="Medium" 
                          HorizontalAlignment="Center" 
                          Foreground="#BDC3C7" 
                          Margin="0,0,0,15"
                          TextAlignment="Center"/>
                
                <!-- Call Duration -->
                <TextBlock x:Name="CallDurationText" 
                          Text="{Binding Duration, FallbackValue='00:00'}"
                          FontSize="14" 
                          HorizontalAlignment="Center" 
                          Foreground="#95A5A6"
                          TextAlignment="Center"/>
            </StackPanel>

            <!-- Action Buttons -->
            <Grid Grid.Row="2" Margin="0,25,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Accept Button - Green with Phone Answer Icon -->
                <Button Grid.Column="0" x:Name="AcceptButton"
                       Style="{StaticResource CircularButtonStyle}"
                       Background="#27AE60"
                       HorizontalAlignment="Center"
                       Click="Accept_Click"
                       ToolTip="Answer Call">
                    <!-- Simplified phone icon (lifted handset) -->
                    <TextBlock Text="📞" FontSize="28" Foreground="White" 
                              RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-20"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Button>

                <!-- Decline Button - Red with Phone Hang Up Icon -->
                <Button Grid.Column="2" x:Name="DeclineButton"
                       Style="{StaticResource CircularButtonStyle}"
                       Background="#E74C3C"
                       HorizontalAlignment="Center"
                       Click="Decline_Click"
                       ToolTip="Decline Call">
                    <!-- Simplified phone icon (hanging up) -->
                    <TextBlock Text="📴" FontSize="28" Foreground="White"/>
                </Button>
            </Grid>

            <!-- Additional Actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" 
                       HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="MuteButton"
                       Background="#95A5A6"
                       Foreground="White"
                       FontSize="12"
                       Padding="15,8"
                       Margin="5,0"
                       BorderThickness="0"
                       Click="Mute_Click"
                       ToolTip="Mute">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="15"
                                               Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,16H19Z" 
                              Fill="White" 
                              Width="12" Height="12" 
                              Stretch="Uniform" 
                              Margin="0,0,5,0"/>
                        <TextBlock Text="Mute" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
