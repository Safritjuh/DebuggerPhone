<UserControl x:Class="WindowsSipPhone.Controls.ThemeToggleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Border Style="{StaticResource ModernCardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,8">
        <StackPanel>
            <TextBlock Text="🎨 Theme Settings" 
                      Style="{StaticResource SubheaderTextStyle}"
                      Margin="0,0,0,16"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Theme Selection -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Appearance:" 
                              Foreground="{StaticResource TextBrush}"
                              FontSize="14"
                              FontWeight="Medium"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    
                    <ComboBox x:Name="ThemeComboBox"
                             Width="120"
                             Style="{StaticResource ModernComboBoxStyle}"
                             SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="☀️ Light" Tag="Light"/>
                        <ComboBoxItem Content="🌙 Dark" Tag="Dark"/>
                        <ComboBoxItem Content="🖥️ Auto" Tag="Auto"/>
                    </ComboBox>
                </StackPanel>
                
                <!-- Quick Toggle Button -->
                <Button x:Name="QuickToggleButton"
                       Grid.Column="1"
                       Content="🌙"
                       Width="40"
                       Height="32"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="QuickToggleButton_Click"
                       ToolTip="Quick toggle Light/Dark theme"
                       Margin="8,0,0,0"/>
            </Grid>
              <!-- Theme Preview -->
            <Border Margin="0,16,0,0" 
                   Background="{StaticResource DividerBrush}" 
                   Padding="12">
                <Border.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="🎨 Theme Preview" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12"
                              FontWeight="Medium"
                              Margin="0,0,0,8"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                          <!-- Primary Color -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Border Background="{StaticResource PrimaryBrush}" 
                                   Height="20" 
                                   CornerRadius="2"
                                   Margin="0,0,0,4"/>
                            <TextBlock Text="Primary" 
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Surface Color -->
                        <StackPanel Grid.Column="1" Margin="4,0">
                            <Border Background="{StaticResource SurfaceBrush}" 
                                   BorderBrush="{StaticResource BorderBrush}"
                                   BorderThickness="1"
                                   Height="20" 
                                   CornerRadius="2"
                                   Margin="0,0,0,4"/>
                            <TextBlock Text="Surface" 
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Text Color -->
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <Border Background="{StaticResource TextBrush}" 
                                   Height="20" 
                                   CornerRadius="2"
                                   Margin="0,0,0,4"/>
                            <TextBlock Text="Text" 
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="10"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
