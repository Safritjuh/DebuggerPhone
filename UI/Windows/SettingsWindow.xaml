<Window x:Class="WindowsSipPhone.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="600" Width="900" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="700">
      <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20,0,0">
                  <!-- SIP Settings -->
                <Button Name="SipSettingsButton" 
                        Content="📞 SIP Settings"
                        Padding="12,8"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="NavigationButton_Click" 
                        Tag="SipSettings"/>

                <!-- Audio Settings -->
                <Button Name="AudioSettingsButton" 
                        Content="🎧 Audio Settings"
                        Padding="12,8"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="NavigationButton_Click" 
                        Tag="AudioSettings"/>

                <!-- Application Settings -->
                <Button Name="AppSettingsButton" 
                        Content="⚙️ App Settings"
                        Padding="12,8"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="NavigationButton_Click" 
                        Tag="AppSettings"/>

                <!-- Debug Tools -->
                <Button Name="DebugToolsButton" 
                        Content="🐛 Debug Tools"
                        Padding="12,8"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="NavigationButton_Click" 
                        Tag="DebugTools"/>

            </StackPanel>
        </Border>        <!-- Right Content Panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content Area -->
            <ScrollViewer Grid.Row="0" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentControl Name="ContentArea"/>
            </ScrollViewer>            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="20,20,20,20">
                <Button Name="OkButton" 
                        Content="OK" 
                        Width="80" 
                        Height="35" 
                        Margin="0,0,10,0"
                        Click="OkButton_Click"/>
                <Button Name="CancelButton" 
                        Content="Cancel" 
                        Width="80" 
                        Height="35"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
