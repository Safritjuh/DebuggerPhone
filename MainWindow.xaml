<Window x:Class="WindowsSipPhone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:WindowsSipPhone.Pages"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Windows SIP Phone - RFC 3261 Compliant" Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource TitleBarBackgroundBrush}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      NonClientFrameEdges="None" 
                      ResizeBorderThickness="4" 
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" 
                Background="{DynamicResource TitleBarBackgroundBrush}"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title and Icon Area -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            Background="Transparent">
                    <TextBlock Text="📞" 
                               FontSize="14" 
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Windows SIP Phone" 
                               FontSize="12" 
                               FontWeight="Normal"
                               Foreground="{DynamicResource TitleBarTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" 
                            Content="&#xE921;" 
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"/>
                    <Button x:Name="MaximizeRestoreButton" 
                            Content="&#xE922;" 
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize"/>
                    <Button x:Name="CloseButton" 
                            Content="&#xE8BB;" 
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Header with Registration Status -->
        <Border Grid.Row="1" Background="#2196F3" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📞 Windows SIP Phone" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="🔗 Status:" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="0,0,5,0"/>
                    <TextBlock x:Name="HeaderStatusText" 
                               Text="Not Registered" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Settings Button -->
                    <Button Content="⚙️ Settings" 
                            Click="Settings_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#607D8B"
                            Margin="0,0,10,0"
                            ToolTip="Open Application Settings"/>
                </StackPanel>
            </Grid>        </Border>
        
        <!-- Main Content Area -->
        <pages:DialerPage x:Name="DialerPageControl" Grid.Row="2"/>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="{DynamicResource SurfaceBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusBarIcon" 
                               Text="⚪" 
                               Margin="0,0,5,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="StatusBarText" 
                               Text="Ready - Configure SIP settings to begin"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🕒" 
                               Margin="0,0,5,0"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="TimeText" 
                               Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm:ss}'}"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
