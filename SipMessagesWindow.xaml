<Window x:Class="WindowsSipPhone.SipMessagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIP Protocol Debugger - Message Ladder View" 
        Height="800" 
        Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">
      <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Enhanced Toolbar -->
        <ToolBar Grid.Row="0" Margin="0,0,0,10" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
            <Button x:Name="ClearButton" Content="🗑️ Clear" 
                    ToolTip="Clear all SIP messages"
                    Background="#FF4444" Foreground="White" 
                    Padding="8,4" Margin="2"/>
            <Separator/>
            <CheckBox x:Name="AutoScrollCheckBox" Content="📜 Auto-scroll" IsChecked="True"
                      ToolTip="Automatically scroll to newest messages"
                      VerticalAlignment="Center"/>
            <Separator/>            <Button x:Name="SaveButton" Content="💾 Save Log"
                    ToolTip="Export SIP message log to file"
                    Background="#4CAF50" Foreground="White"
                    Padding="8,4" Margin="2"/>
            <Separator/>
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="5,0"/>
            <ComboBox x:Name="MessageFilterComboBox" Width="120" SelectedIndex="0"
                      ToolTip="Filter messages by type">
                <ComboBoxItem Content="All Messages"/>
                <ComboBoxItem Content="REGISTER"/>
                <ComboBoxItem Content="INVITE"/>
                <ComboBoxItem Content="BYE"/>
                <ComboBoxItem Content="200 OK"/>
                <ComboBoxItem Content="4xx/5xx Errors"/>
                <ComboBoxItem Content="Authentication"/>
            </ComboBox>
        </ToolBar>        
        <!-- SIP Protocol Analysis Header -->
        <Border Grid.Row="1" Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📡 CLIENT" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ClientInfoLabel" Text="192.168.1.100:5060" Foreground="#BDC3C7" 
                               HorizontalAlignment="Center" FontSize="11"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⟵" FontSize="20" Foreground="#E74C3C" Margin="5,0"/>
                    <TextBlock Text="SIP/2.0 over TCP" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="⟶" FontSize="20" Foreground="#27AE60" Margin="5,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2">
                    <TextBlock Text="🖥️ SERVER" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ServerInfoLabel" Text="192.168.1.180:5060" Foreground="#BDC3C7" 
                               HorizontalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
          <!-- Conversation Selection -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Conversation Filter Panel -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="📞 Conversation:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <ComboBox x:Name="ConversationComboBox" Grid.Column="1" MinWidth="300" 
                              ToolTip="Select a conversation by Call-ID to filter messages"
                              SelectionChanged="ConversationComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CallId}" FontFamily="Consolas" FontSize="10" Width="200"/>
                                    <TextBlock Text="{Binding MessageCount}" FontWeight="Bold" Margin="10,0,5,0"/>
                                    <TextBlock Text="messages" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding LastActivity}" FontSize="9" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button x:Name="ShowAllConversationsButton" Grid.Column="2" Content="📋 Show All" 
                            Margin="10,0,0,0" Padding="8,4" 
                            ToolTip="Show messages from all conversations"
                            Click="ShowAllConversationsButton_Click"/>
                    <TextBlock x:Name="ConversationStatsLabel" Grid.Column="3" 
                               Text="0 conversations" 
                               VerticalAlignment="Center" 
                               Margin="15,0,0,0" 
                               FontSize="11" 
                               Foreground="Gray"/>
                </Grid>
            </Border>
            
            <!-- Enhanced Messages Display with Tabs -->
            <TabControl Grid.Row="1" Background="White">
            <TabItem Header="📋 Raw Messages">
                <ScrollViewer x:Name="MessagesScrollViewer" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Auto"
                              Background="#1E1E1E">
                    <TextBox x:Name="MessagesTextBox" 
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             Background="#1E1E1E"
                             Foreground="#00FF00"
                             BorderThickness="0"
                             Padding="10"/>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="🪜 Ladder View">
                <ScrollViewer x:Name="LadderScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Background="White">
                    <Canvas x:Name="LadderCanvas" 
                            Background="White"
                            MinHeight="400"
                            MinWidth="800"/>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="📊 Message Analysis">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <ListView x:Name="MessageListView" Grid.Column="0" Margin="5"
                              Background="White" BorderBrush="#E0E0E0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="80" DisplayMemberBinding="{Binding Timestamp}"/>
                                <GridViewColumn Header="Direction" Width="80" DisplayMemberBinding="{Binding Direction}"/>
                                <GridViewColumn Header="Method/Response" Width="120" DisplayMemberBinding="{Binding MessageType}"/>
                                <GridViewColumn Header="Summary" Width="300" DisplayMemberBinding="{Binding Summary}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    
                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="📈 Statistics" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TotalMessagesLabel" Text="Total Messages: 0"/>
                        <TextBlock x:Name="OutgoingCountLabel" Text="Outgoing: 0"/>
                        <TextBlock x:Name="IncomingCountLabel" Text="Incoming: 0"/>
                        <TextBlock x:Name="ErrorCountLabel" Text="Errors: 0"/>
                        <Separator Margin="0,10"/>
                        <TextBlock Text="🔄 Recent Activity" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="RecentActivityText" Height="120" IsReadOnly="True" 
                                 TextWrapping="Wrap" FontSize="10" Background="#F8F9FA"/>
                    </StackPanel>
                </Grid>
            </TabItem>        </TabControl>
        </Grid>
        
        <!-- Enhanced Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0" Background="#34495E">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="MessageCountLabel" Text="0 messages" Foreground="White"/>
                    <Separator Margin="10,0"/>
                    <TextBlock x:Name="LastUpdateLabel" Text="Last update: Never" Foreground="#BDC3C7"/>
                    <Separator Margin="10,0"/>
                    <TextBlock x:Name="ConnectionStatusLabel" Text="🔴 Disconnected" Foreground="#E74C3C"/>
                    <Separator Margin="10,0"/>
                    <TextBlock x:Name="ProtocolVersionLabel" Text="SIP/2.0 RFC 3261" Foreground="#95A5A6"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
