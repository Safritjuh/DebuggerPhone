<UserControl x:Class="WindowsSipPhone.Pages.DialerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:WindowsSipPhone.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>    <Grid>
        <!-- Main Content Area -->
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
              <!-- Left Panel - Dialer -->
            <Border Grid.Column="0" Background="#ECF0F1" CornerRadius="10" Margin="0,0,10,0">
                <Grid Margin="20">                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                      <!-- Title -->
                    <TextBlock Grid.Row="0" Text="Number Pad" FontSize="18" FontWeight="Bold" 
                              Foreground="#2C3E50" Margin="0,0,0,15"/>
                      <!-- Call Status Display (visible during active calls) -->
                    <Border Grid.Row="1" Background="#E8F5E8" BorderBrush="#27AE60" BorderThickness="2" 
                           CornerRadius="5" Margin="0,0,0,10"
                           Visibility="{Binding IsCallActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="10" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CallStatusText}" FontSize="16" FontWeight="Bold" 
                                      Foreground="#27AE60" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CallDurationText}" FontSize="14" 
                                      Foreground="#27AE60" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            <!-- DTMF Status Display -->
                            <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" 
                                   CornerRadius="3" Margin="0,5,0,0" Padding="5"
                                   Visibility="{Binding IsDtmfActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding DtmfStatusText}" FontSize="12" FontWeight="Bold" 
                                          Foreground="#856404" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Number Display -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="2" 
                           CornerRadius="5" Margin="0,0,0,15"
                           Visibility="{Binding IsCallActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBox Name="NumberDisplay" FontSize="20" FontWeight="Bold" 
                                Text="{Binding DialedNumber, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" 
                                Background="Transparent" BorderThickness="0" Margin="10"
                                IsReadOnly="False" TextAlignment="Center"/>
                    </Border>
                      <!-- Number Pad / DTMF Keypad -->
                    <Grid Grid.Row="2" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Row 1 -->
                        <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource NumberButtonStyle}" 
                               Command="{Binding KeypadCommand}" CommandParameter="1"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="2"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="3"/>
                        
                        <!-- Row 2 -->
                        <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="6"/>
                        
                        <!-- Row 3 -->
                        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="7"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="8"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="9"/>
                        
                        <!-- Row 4 -->
                        <Button Grid.Row="3" Grid.Column="0" Content="*" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="*"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="#" Style="{StaticResource NumberButtonStyle}"
                               Command="{Binding KeypadCommand}" CommandParameter="#"/>
                    </Grid>                    <!-- Action Buttons -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="🗑️ Clear" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding ClearCommand}" Background="#E74C3C" Margin="0,0,2,0"
                               IsEnabled="{Binding IsCallActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <Button Grid.Column="1" Content="📞 Call" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding CallCommand}" Background="#27AE60" Margin="2,0,2,0"
                               Visibility="{Binding IsCallActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        
                        <!-- Hold/Resume Button (visible during active calls) -->
                        <Button Grid.Column="1" Content="{Binding HoldButtonText}" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding HoldCommand}" Background="#9B59B6" Margin="2,0,2,0"
                               Visibility="{Binding IsCallActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                               ToolTip="Hold or resume current call"/>
                        
                        <Button Grid.Column="2" Content="{Binding AudioButtonText}" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding AudioCommand}" Background="#3498DB" Margin="2,0,2,0"
                               Visibility="{Binding IsCallActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                               ToolTip="Audio controls: mute/unmute microphone"/>
                        
                        <Button Grid.Column="3" Content="📵 Hangup" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding HangupCommand}" Background="#E67E22" Margin="2,0,0,0"
                               IsEnabled="{Binding IsCallActive}"/>
                    </Grid>
                    
                    <!-- Test/Debug Buttons (visible only when not in call) -->                    <!-- Test Call and Refresh buttons removed for cleaner UI -->
                    <!-- Row 4 intentionally left empty for potential future use -->
                      <!-- Volume Control Section (visible during active calls) -->
                    <Border Grid.Row="5" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" 
                           CornerRadius="5" Margin="0,10,0,0"
                           Visibility="{Binding IsCallActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Volume Control Title -->
                            <TextBlock Grid.Row="0" Text="🔊 Audio Control" FontSize="14" FontWeight="Bold" 
                                      Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            
                            <!-- Volume Slider -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="🔉" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding AudioVolume}" 
                                       TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                       ToolTip="{Binding AudioVolume, StringFormat='Volume: {0:P0}'}"
                                       Margin="5,0,5,0"/>
                                <TextBlock Grid.Column="2" Text="🔊" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>                        </Grid>
                    </Border>
                      <!-- SIP Protocol Test Section - REMOVED per task requirements -->
                </Grid>
            </Border>
            
            <!-- Right Panel - Call History -->
            <Border Grid.Column="1" Background="#ECF0F1" CornerRadius="10" Margin="10,0,0,0">
                <Grid Margin="20">                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Title -->
                    <TextBlock Grid.Row="0" Text="Call History" FontSize="18" FontWeight="Bold" 
                              Foreground="#2C3E50" Margin="0,0,0,15"/>                    <!-- Filter Buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="All" Style="{StaticResource FilterButtonStyle}" 
                               Command="{Binding FilterCallsCommand}" CommandParameter="All" Margin="0,0,5,0"/>
                        <Button Content="📞→ Outgoing" Style="{StaticResource FilterButtonStyle}"
                               Command="{Binding FilterCallsCommand}" CommandParameter="Outgoing" Margin="5,0,5,0"/>
                        <Button Content="📞← Incoming" Style="{StaticResource FilterButtonStyle}"
                               Command="{Binding FilterCallsCommand}" CommandParameter="Incoming" Margin="5,0,5,0"/>
                        <Button Content="📞❌ Missed" Style="{StaticResource FilterButtonStyle}"
                               Command="{Binding FilterCallsCommand}" CommandParameter="Missed" Margin="5,0,0,0"/>
                    </StackPanel>                    <!-- Column Headers -->
                    <Border Grid.Row="2" Background="#ECF0F1" BorderBrush="#BDC3C7" 
                           BorderThickness="1,1,1,0" Margin="0,0,0,0">
                        <Grid Margin="8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="120"/>      <!-- Column 1: Name and Number -->
                                <ColumnDefinition Width="*" MinWidth="100"/>      <!-- Column 2: Date/Time -->
                                <ColumnDefinition Width="80"/>                    <!-- Column 3: Duration -->
                            </Grid.ColumnDefinitions>
                            
                            <!-- Column 1: Contact Header -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📞" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0"/>
                                <TextBlock Text="Contact" FontWeight="Bold" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Column 2: Date & Time Header -->
                            <TextBlock Grid.Column="1" Text="Date &amp; Time" FontWeight="Bold" 
                                      FontSize="12" Foreground="#2C3E50" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            
                            <!-- Column 3: Duration Header -->
                            <TextBlock Grid.Column="2" Text="Duration" FontWeight="Bold" 
                                      FontSize="12" Foreground="#2C3E50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border><!-- Call History List -->
                    <ListView Grid.Row="3" ItemsSource="{Binding FilteredCallHistory}" 
                             SelectedItem="{Binding SelectedCall}" Background="White" 
                             BorderBrush="#BDC3C7" BorderThickness="1,0,1,1" Margin="0,0,0,0"><ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120"/>      <!-- Column 1: Name and Number -->
                                        <ColumnDefinition Width="*" MinWidth="100"/>      <!-- Column 2: Date/Time -->
                                        <ColumnDefinition Width="80"/>                    <!-- Column 3: Duration -->
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Column 1: Call Type Icon + Name/Number -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CallTypeIcon}" FontSize="18" 
                                                  VerticalAlignment="Center" Margin="0,0,8,0" 
                                                  Foreground="{Binding CallTypeColor}"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13"
                                                      Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Number}" FontSize="11" 
                                                      Foreground="#7F8C8D" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Column 2: Start Date and Time -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding DateTime, StringFormat='MMM dd, yyyy'}" 
                                                  FontSize="12" Foreground="#2C3E50" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DateTime, StringFormat='HH:mm'}" 
                                                  FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>
                                    
                                    <!-- Column 3: Conversation Duration -->
                                    <TextBlock Grid.Column="2" Text="{Binding DurationText}" 
                                              FontSize="12" FontWeight="SemiBold" 
                                              Foreground="#27AE60" VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" TextAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>                    <!-- History Actions -->
                    <Grid Grid.Row="4" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="📞 Redial" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding RedialCommand}" Background="#3498DB" Margin="0,0,3,0"/>
                        <Button Grid.Column="1" Content="📊 Export CSV" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding ExportCsvCommand}" Background="#F39C12" Margin="3,0,3,0"/>
                        <Button Grid.Column="2" Content="🗑️ Clear History" Style="{StaticResource ActionButtonStyle}"
                               Command="{Binding ClearHistoryCommand}" Background="#95A5A6" Margin="3,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
