<Window x:Class="WindowsSipPhone.IncomingCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Incoming Call" Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow" 
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="CircularButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#2C3E50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Incoming Call" 
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Foreground="White" 
                   Margin="0,20,0,15"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="20">
            <TextBlock x:Name="CallerNameText" 
                       Text="{Binding CallerName}"
                       FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Foreground="White" 
                       Margin="0,0,0,10"
                       TextAlignment="Center"/>
            
            <TextBlock x:Name="CallerNumberText" 
                       Text="{Binding CallerNumber}"
                       FontSize="16" 
                       HorizontalAlignment="Center" 
                       Foreground="#BDC3C7" 
                       TextAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="40,20,40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>            <Button Grid.Column="0" x:Name="AcceptButton"
                    Background="#27AE60"
                    Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    BorderThickness="0"
                    Padding="20,12"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Click="Accept_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="25"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                Answer
            </Button>

            <Button Grid.Column="2" x:Name="DeclineButton"
                    Background="#E74C3C"
                    Foreground="White"
                    FontSize="16" FontWeight="Bold"
                    BorderThickness="0"
                    Padding="20,12"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Click="Decline_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="25"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                Decline
            </Button>
        </Grid>
    </Grid>
</Window>