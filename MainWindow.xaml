<Window x:Class="WindowsSipPhone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:WindowsSipPhone.Pages"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Windows SIP Phone - RFC 3261 Compliant" Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header with Registration Status -->
        <Border Grid.Row="0" Background="#2196F3" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📞 Windows SIP Phone" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="🔗 Status:" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="0,0,5,0"/>
                    <TextBlock x:Name="HeaderStatusText" 
                               Text="Not Registered" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Settings Button -->
                    <Button Content="⚙️ Settings" 
                            Click="Settings_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#607D8B"
                            Margin="0,0,10,0"
                            ToolTip="Open Application Settings"/>
                </StackPanel>
            </Grid>        </Border>
        
        <!-- Main Content Area -->
        <pages:DialerPage x:Name="DialerPageControl" Grid.Row="1"/>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#F5F5F5">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusBarIcon" Text="⚪" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusBarText" Text="Ready - Configure SIP settings to begin"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🕒" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TimeText" Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm:ss}'}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
