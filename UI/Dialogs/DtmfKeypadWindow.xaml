<Window x:Class="WindowsSipPhone.UI.Dialogs.DtmfKeypadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:WindowsSipPhone.UI.Converters"
        mc:Ignorable="d"
        Title="DTMF Keypad" 
        Height="450" Width="350"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        Background="#ECF0F1">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- DTMF Button Style -->
        <Style x:Key="DtmfButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                               CornerRadius="8" 
                               BorderThickness="{TemplateBinding BorderThickness}"
                               BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1F4E79"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🔢 DTMF Keypad" FontSize="18" FontWeight="Bold" 
                  Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
        
        <!-- Status Display -->
        <Border Grid.Row="1" Background="#E8F5E8" BorderBrush="#27AE60" BorderThickness="2" 
               CornerRadius="5" Margin="0,0,0,15" Padding="10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding CallStatusText}" FontSize="14" FontWeight="Bold" 
                          Foreground="#27AE60" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding DtmfStatusText}" FontSize="12" FontWeight="Bold" 
                          Foreground="#856404" HorizontalAlignment="Center" Margin="0,5,0,0"
                          Visibility="{Binding IsDtmfActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
        
        <!-- DTMF Keypad -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Row 1 -->
            <Button Grid.Row="0" Grid.Column="0" Content="1" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="1"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="2"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="3" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="3"
                   Style="{StaticResource DtmfButtonStyle}"/>
            
            <!-- Row 2 -->
            <Button Grid.Row="1" Grid.Column="0" Content="4" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="4"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="5"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="6"
                   Style="{StaticResource DtmfButtonStyle}"/>
            
            <!-- Row 3 -->
            <Button Grid.Row="2" Grid.Column="0" Content="7" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="7"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="2" Grid.Column="1" Content="8" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="8"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="2" Grid.Column="2" Content="9" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="9"
                   Style="{StaticResource DtmfButtonStyle}"/>
            
            <!-- Row 4 -->
            <Button Grid.Row="3" Grid.Column="0" Content="*" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="*"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="3" Grid.Column="1" Content="0" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="0"
                   Style="{StaticResource DtmfButtonStyle}"/>
            <Button Grid.Row="3" Grid.Column="2" Content="#" 
                   Command="{Binding DtmfKeypadCommand}" CommandParameter="#"
                   Style="{StaticResource DtmfButtonStyle}"/>
        </Grid>
        
        <!-- Close Button -->
        <Button Grid.Row="3" Content="✖ Close" 
               Click="CloseButton_Click"
               Style="{StaticResource ActionButtonStyle}"
               Background="#95A5A6"               HorizontalAlignment="Center"
               Width="120"/>
    </Grid>
</Window>
