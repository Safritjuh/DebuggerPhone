<UserControl x:Class="WindowsSipPhone.UI.Controls.ErrorMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Border x:Name="ErrorBorder"
           Background="{StaticResource ErrorBackgroundBrush}" 
           BorderBrush="{StaticResource ErrorBrush}"
           BorderThickness="1"
           CornerRadius="6" 
           Padding="16"
           Margin="0,8"
           Visibility="Collapsed">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Error Icon -->
            <TextBlock x:Name="ErrorIcon"
                      Grid.Column="0"
                      Text="⚠️"
                      FontSize="16"
                      VerticalAlignment="Top"
                      Margin="0,0,12,0"/>
            
            <!-- Error Content -->
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="ErrorTitle"
                          Text="Error"
                          FontWeight="Bold"
                          FontSize="14"
                          Foreground="{StaticResource ErrorBrush}"
                          Margin="0,0,0,4"/>
                
                <TextBlock x:Name="ErrorMessage"
                          Text=""
                          FontSize="12"
                          Foreground="{StaticResource ErrorBrush}"
                          TextWrapping="Wrap"
                          Margin="0,0,0,8"/>
                
                <StackPanel x:Name="ErrorActions" 
                           Orientation="Horizontal" 
                           Visibility="Collapsed">
                    <Button x:Name="RetryButton"
                           Content="🔄 Retry"
                           Style="{StaticResource SmallButtonStyle}"
                           Click="RetryButton_Click"
                           Margin="0,0,8,0"/>
                    
                    <Button x:Name="DetailsButton"
                           Content="📋 Details"
                           Style="{StaticResource SmallSecondaryButtonStyle}"
                           Click="DetailsButton_Click"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Auto-dismiss countdown -->
            <TextBlock x:Name="CountdownText"
                      Grid.Column="2"
                      Text=""
                      FontSize="10"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      VerticalAlignment="Top"
                      Margin="12,0,12,0"
                      Visibility="Collapsed"/>
            
            <!-- Close Button -->
            <Button x:Name="CloseButton"
                   Grid.Column="3"
                   Content="✕"
                   Style="{StaticResource SmallSecondaryButtonStyle}"
                   Width="24"
                   Height="24"
                   Click="CloseButton_Click"
                   VerticalAlignment="Top"/>
        </Grid>
    </Border>
</UserControl>
