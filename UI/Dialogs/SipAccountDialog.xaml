<Window x:Class="WindowsSipPhone.UI.Dialogs.SipAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIP Account Settings" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="SIP Account Configuration" 
                   FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="UsernameTextBox" 
                         Text="103" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" 
                             VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Server:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ServerTextBox" 
                         Text="192.168.1.180" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Port:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="PortTextBox" 
                         Text="5060" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Transport:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="TransportComboBox" 
                          SelectedIndex="0" VerticalContentAlignment="Center" Margin="5,0,0,0">
                    <ComboBoxItem Content="TCP"/>
                    <ComboBoxItem Content="UDP"/>
                    <ComboBoxItem Content="TLS"/>
                </ComboBox>
                
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Display Name:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="DisplayNameTextBox" 
                         Text="Extension 103" VerticalContentAlignment="Center" Margin="5,0,0,0"/>
                
                <CheckBox Grid.Row="6" Grid.Column="1" x:Name="AutoRegisterCheckBox" 
                          Content="Auto-register on startup" 
                          IsChecked="True" Margin="5,5,0,0"/>
                
                <GroupBox Grid.Row="7" Grid.ColumnSpan="2" Header="Test Connection" Margin="0,10,0,0">
                    <StackPanel Margin="10">
                        <Button x:Name="TestConnectionButton" Content="Test Connection" 
                                Click="TestConnection_Click" Height="30" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TestResultText" Text="Click 'Test Connection' to verify server connectivity" 
                                   TextWrapping="Wrap" FontSize="10"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Click="OK_Click" Width="75" Height="30" Margin="0,0,10,0"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="75" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
