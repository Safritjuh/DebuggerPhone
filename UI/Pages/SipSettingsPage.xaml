<UserControl x:Class="WindowsSipPhone.UI.Pages.SipSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Button Styles -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                               CornerRadius="5" 
                               BorderBrush="{TemplateBinding BorderBrush}" 
                               BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- TextBox Style -->
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        
        <!-- ComboBox Style -->
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#3498DB" Padding="20,15,20,15">
            <StackPanel>
                <TextBlock Text="📞 SIP Settings" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="Configure SIP profiles and unified registration settings" 
                          FontSize="12" 
                          Foreground="#D6EAF8" 
                          Margin="0,3,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                     PanningMode="VerticalOnly" 
                     CanContentScroll="True">            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Panel - Combined Registration & Advanced Settings -->
                <Border Grid.Column="0" Background="#ECF0F1" CornerRadius="10" Margin="0,0,10,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                 PanningMode="VerticalOnly" 
                                 CanContentScroll="True">                        <StackPanel Margin="15">
                            <TextBlock Text="⚙️ Registration &amp; Advanced Settings" FontSize="18" FontWeight="Bold" 
                                      Foreground="#2C3E50" Margin="0,0,0,15"/>
                            
                            <!-- Account Credentials Section -->
                            <Border Background="#D5DBDB" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                                <StackPanel>                                    <TextBlock Text="🔐 Account Credentials" FontSize="14" FontWeight="Bold" 
                                              Foreground="#2C3E50" Margin="0,0,0,10"/>
                                      <!-- Username -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="Username:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Name="UsernameTextBox" 
                                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource SettingsTextBoxStyle}"/>
                                    </Grid>
                                    
                                    <!-- Password -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="Password:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <PasswordBox Grid.Column="1" Name="PasswordBox" 
                                                    Height="35" FontSize="14" Padding="10,5"
                                                    BorderBrush="#BDC3C7" BorderThickness="2" Background="White"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                              <!-- Server Configuration Section -->
                            <Border Background="#D5DBDB" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="🌐 Server Configuration" FontSize="14" FontWeight="Bold" 
                                              Foreground="#2C3E50" Margin="0,0,0,10"/>
                                      <!-- Server Host -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="SIP Server:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Name="ServerHostTextBox" 
                                                Text="{Binding ServerHost, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource SettingsTextBoxStyle}"/>
                                    </Grid>
                                      <!-- Server Port and Transport on same line -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="Port:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Name="ServerPortTextBox" 
                                                Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource SettingsTextBoxStyle}"/>
                                        
                                        <TextBlock Grid.Column="3" Text="Transport:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Column="4" Name="TransportComboBox" 
                                                 SelectedValue="{Binding SelectedTransport}"
                                                 SelectedIndex="0"
                                                 Style="{StaticResource SettingsComboBoxStyle}">
                                            <ComboBoxItem Content="TCP" Tag="TCP" IsSelected="True"/>
                                            <ComboBoxItem Content="UDP" Tag="UDP"/>
                                            <ComboBoxItem Content="TLS" Tag="TLS"/>
                                        </ComboBox>
                                    </Grid>
                                    
                                    <!-- Info text -->
                                    <TextBlock Text="Auto-filled from profile, editable" 
                                              FontSize="11" Foreground="#3498DB" Margin="120,0,0,0"/>
                                </StackPanel>
                            </Border>                              <!-- Advanced SIP Settings Section -->
                            <Border Background="#D5DBDB" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="🔧 Advanced SIP Settings" FontSize="14" FontWeight="Bold" 
                                                  Foreground="#2C3E50"/>
                                        <TextBlock Text="📋 Auto-filled from profile" FontSize="11" 
                                                  Foreground="#3498DB" FontStyle="Italic" 
                                                  Margin="10,2,0,0" VerticalAlignment="Bottom"/>
                                    </StackPanel>                                    <!-- Registration Expires and User Agent on same line -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="Reg. Expires:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Name="ExpiresTextBox" 
                                                Text="{Binding RegistrationExpires, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource SettingsTextBoxStyle}"/>
                                        
                                        <TextBlock Grid.Column="3" Text="User Agent:" FontWeight="Bold" 
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="4" Name="UserAgentTextBox" 
                                                Text="{Binding UserAgent, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource SettingsTextBoxStyle}"/>
                                    </Grid>
                                    
                                    <!-- Info text -->
                                    <TextBlock Text="Auto-filled from profile, editable" 
                                              FontSize="11" Foreground="#3498DB" Margin="120,0,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Registration Actions -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="🔌 Register" 
                                       Command="{Binding RegisterCommand}"
                                       Style="{StaticResource ActionButtonStyle}"
                                       Background="#27AE60" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="🔌 Unregister" 
                                       Command="{Binding UnregisterCommand}"
                                       Style="{StaticResource ActionButtonStyle}"
                                       Background="#E74C3C" Margin="5,0,0,0"/>
                            </Grid>
                            
                            <!-- Settings Action Buttons -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="💾 Save Settings" 
                                       Command="{Binding SaveSettingsCommand}"
                                       Style="{StaticResource ActionButtonStyle}"
                                       Background="#3498DB" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="🔄 Reset to Defaults" 
                                       Command="{Binding ResetSettingsCommand}"
                                       Style="{StaticResource ActionButtonStyle}"
                                       Background="#95A5A6" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Right Panel - Profile Selection -->                <Border Grid.Column="1" Background="#ECF0F1" CornerRadius="10" Margin="10,0,0,0">
                    <StackPanel Margin="15">
                        <TextBlock Text="🚀 SIP Profile Selection" FontSize="18" FontWeight="Bold" 
                                  Foreground="#2C3E50" Margin="0,0,0,15"/>
                        
                        <!-- SIP Profile Selection (Enhanced IMP-016) -->
                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="📞 Available Profiles" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox Grid.Row="1" Name="ProfileComboBox" 
                                     ItemsSource="{Binding AvailableProfiles}"
                                     SelectedItem="{Binding SelectedProfile}"
                                     Style="{StaticResource SettingsComboBoxStyle}"/>
                            <TextBlock Grid.Row="2" Text="{Binding ProfileDetails}" 
                                      FontSize="11" Foreground="#7F8C8D" Margin="0,3,0,0" TextWrapping="Wrap"/>
                        </Grid>
                          <!-- Profile Quick Info -->
                        <Border Background="#D5DBDB" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📋 Profile Overview" FontSize="14" FontWeight="Bold" 
                                          Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding ProfileDetails}" FontSize="11" 
                                          Foreground="#2C3E50" TextWrapping="Wrap" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                          <!-- Profile Management Buttons -->
                        <Grid Margin="0,8,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Button Grid.Row="0" Content="📤 Export Profile" 
                                   Command="{Binding ExportProfileCommand}"
                                   Style="{StaticResource ActionButtonStyle}"
                                   Background="#8E44AD" Margin="0,0,0,10"/>
                            <Button Grid.Row="1" Content="📥 Import Profile" 
                                   Command="{Binding ImportProfileCommand}"
                                   Style="{StaticResource ActionButtonStyle}"
                                   Background="#E67E22"/>
                        </Grid>
                        
                        <!-- Registration Status -->
                        <Border Background="{Binding StatusBackgroundBrush}" 
                               CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock Text="{Binding RegistrationStatus}" FontWeight="Bold" 
                                          Foreground="White" HorizontalAlignment="Center" FontSize="16"/>
                                <TextBlock Text="{Binding StatusDetails}" FontSize="12" 
                                          Foreground="White" HorizontalAlignment="Center" 
                                          Margin="0,5,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0:HH:mm:ss}'}" 
                                          FontSize="10" Foreground="White" HorizontalAlignment="Center" 
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
