<UserControl x:Class="WindowsSipPhone.UI.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"             xmlns:controls="clr-namespace:WindowsSipPhone.UI.Controls"
             xmlns:converters="clr-namespace:WindowsSipPhone.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Converters -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <!-- Button Styles -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                               CornerRadius="3" 
                               BorderBrush="{TemplateBinding BorderBrush}" 
                               BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Filter Button Style -->
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🔍 System Diagnostics" 
                      Style="{StaticResource HeaderTextStyle}"
                      Margin="0,0,0,8"/>
            <TextBlock Text="Monitor system health and troubleshoot connectivity issues" 
                      Style="{StaticResource SubtextStyle}"/>
        </StackPanel>
          <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Error Message Control -->
                <controls:ErrorMessageControl x:Name="ErrorMessage"/>
                
                <!-- Network Diagnostics Control -->
                <controls:NetworkDiagnosticsControl x:Name="NetworkDiagnostics" 
                                                   Margin="0,0,0,16"/>
                
                <!-- SIP Server Health Control -->
                <controls:SipServerHealthControl x:Name="SipServerHealth" 
                                               Margin="0,0,0,16"/>
                
                <!-- Audio Device Health Control -->
                <controls:AudioDeviceHealthControl x:Name="AudioDeviceHealth" 
                                                  Margin="0,0,0,16"/>
                
                <!-- Generate Full Report -->
                <Border Style="{StaticResource ModernCardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,8">
                    <StackPanel>
                        <TextBlock Text="📋 Diagnostic Report" 
                                  Style="{StaticResource SubheaderTextStyle}"
                                  Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Generate a comprehensive diagnostic report for troubleshooting and support." 
                                  Style="{StaticResource SubtextStyle}"
                                  Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="GenerateReportButton"
                                   Grid.Column="0"
                                   Content="📋 Generate Full Report"
                                   Style="{StaticResource ModernButtonStyle}"
                                   Click="GenerateReportButton_Click"
                                   Margin="0,0,8,0"/>
                            
                            <Button x:Name="OpenReportFolderButton"
                                   Grid.Column="1"
                                   Content="📁 Open Reports"
                                   Style="{StaticResource SecondaryButtonStyle}"
                                   Click="OpenReportFolderButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
                  <!-- Existing diagnostics content -->
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Background="#8E44AD" Padding="20,15">
                        <TextBlock Text="🔍 SIP Diagnostics &amp; Traces" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    
                    <Grid Grid.Row="1" Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Panel - SIP Message Traces -->
                        <Border Grid.Column="0" Background="#ECF0F1" CornerRadius="10" Margin="0,0,10,0">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Title and Controls -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="📋 SIP Message Traces" FontSize="18" FontWeight="Bold" 
                                              Foreground="#2C3E50" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox Content="Enable Tracing" IsChecked="{Binding IsTracingEnabled}" 
                                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <Button Content="🗑️ Clear" Command="{Binding ClearTracesCommand}" 
                                               Style="{StaticResource ActionButtonStyle}" Background="#E74C3C" Width="60"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Filter Controls -->
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="All" Command="{Binding FilterCommand}" CommandParameter="All"
                                               Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                        <Button Content="REGISTER" Command="{Binding FilterCommand}" CommandParameter="REGISTER"
                                               Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                        <Button Content="INVITE" Command="{Binding FilterCommand}" CommandParameter="INVITE"
                                               Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                        <Button Content="BYE" Command="{Binding FilterCommand}" CommandParameter="BYE"
                                               Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                        <Button Content="2xx" Command="{Binding FilterCommand}" CommandParameter="2xx"
                                               Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                        <Button Content="4xx" Command="{Binding FilterCommand}" CommandParameter="4xx"
                                               Style="{StaticResource FilterButtonStyle}"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="2" Content="💾 Export" Command="{Binding ExportTracesCommand}"
                                           Style="{StaticResource ActionButtonStyle}" Background="#3498DB" Width="70"/>
                                </Grid>
                                
                                <!-- SIP Messages List -->
                                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredSipMessages}" 
                                        SelectedItem="{Binding SelectedMessage}"
                                        Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2" Padding="8" 
                                                   Background="{Binding BackgroundBrush}"
                                                   BorderBrush="{Binding BorderBrush}" 
                                                   BorderThickness="1" CornerRadius="3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" 
                                                              FontFamily="Consolas" FontSize="11" Foreground="#7F8C8D" 
                                                              VerticalAlignment="Top" Margin="0,0,10,0"/>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding DirectionIcon}" 
                                                              FontSize="14" VerticalAlignment="Top" Margin="0,0,10,0"/>
                                                    
                                                    <TextBlock Grid.Column="2" Text="{Binding Summary}" 
                                                              FontFamily="Consolas" FontSize="12" 
                                                              TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                    
                                                    <TextBlock Grid.Column="3" Text="{Binding MessageType}" 
                                                              FontSize="11" FontWeight="Bold" 
                                                              Foreground="{Binding TypeColor}" 
                                                              VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <!-- Message Details -->
                                <Expander Grid.Row="3" Header="📄 Message Details" Margin="0,10,0,0" Background="White">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <TextBox Text="{Binding SelectedMessage.FullMessage, Mode=OneWay}" 
                                                FontFamily="Consolas" FontSize="11" 
                                                IsReadOnly="True" Background="Transparent" 
                                                BorderThickness="0" TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Expander>
                            </Grid>
                        </Border>
                        
                        <!-- Right Panel - Network Diagnostics -->
                        <Border Grid.Column="1" Background="#ECF0F1" CornerRadius="10" Margin="10,0,0,0">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Network Status -->
                                <TextBlock Grid.Row="0" Text="🌐 Network Diagnostics" FontSize="16" FontWeight="Bold" 
                                          Foreground="#2C3E50" Margin="0,0,0,15"/>
                                
                                <!-- Connection Status -->
                                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Connection Status" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Ellipse Grid.Column="0" Width="12" Height="12" 
                                                    Fill="{Binding ConnectionStatusColor}" 
                                                    VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" 
                                                      VerticalAlignment="Center" FontSize="12"/>
                                        </Grid>
                                        
                                        <TextBlock Text="{Binding LocalEndpoint}" FontSize="11" 
                                                  Foreground="#7F8C8D" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding RemoteEndpoint}" FontSize="11" 
                                                  Foreground="#7F8C8D"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Ping/Latency Test -->
                                <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Network Tests" FontWeight="Bold" Margin="0,0,0,5"/>
                                        
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Latency:" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Latency}" FontSize="12" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Packet Loss:" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PacketLoss}" FontSize="12" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Button Content="🔄 Test Connection" Command="{Binding TestConnectionCommand}"
                                               Style="{StaticResource ActionButtonStyle}" Background="#2ECC71" 
                                               Height="30" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Statistics -->
                                <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Statistics" FontWeight="Bold" Margin="0,0,0,10"/>
                                        
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Messages Sent:" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding MessagesSent}" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Messages Received:" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding MessagesReceived}" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Registration Count:" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding RegistrationCount}" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Uptime:" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Uptime}" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <Button Content="📊 Reset Stats" Command="{Binding ResetStatsCommand}"
                                               Style="{StaticResource ActionButtonStyle}" Background="#95A5A6" Height="30"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>                    </Grid>
                </Grid>
                
                <!-- APPLICATION LOGGING SECTION -->
                <Border Background="White" CornerRadius="10" Margin="20" 
                       BorderBrush="#D5DBDB" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Logging Header -->
                        <Border Grid.Row="0" Background="#3498DB" Padding="20,15,20,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="📝 Application Logging &amp; Diagnostics" 
                                              FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Track errors, actions, and system events in real-time" 
                                              FontSize="12" Foreground="#D5F4FF" Margin="0,3,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <!-- Enable/Disable Toggle -->
                                    <Button x:Name="ToggleLoggingButton"
                                           Content="{Binding LoggingButtonText}"
                                           Background="{Binding LoggingButtonColor}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Height="35"
                                           Padding="15,0"
                                           BorderThickness="0"
                                           Cursor="Hand"
                                           Click="ToggleLoggingButton_Click"
                                           Margin="0,0,10,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                   CornerRadius="3" 
                                                                   BorderBrush="{TemplateBinding BorderBrush}" 
                                                                   BorderThickness="{TemplateBinding BorderThickness}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <!-- Write Log Button -->
                                    <Button x:Name="WriteLogButton"
                                           Content="💾 Write Log"
                                           Background="#27AE60"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Height="35"
                                           Padding="15,0"
                                           BorderThickness="0"
                                           Cursor="Hand"
                                           Click="WriteLogButton_Click"
                                           Margin="0,0,10,0"
                                           Style="{StaticResource ActionButtonStyle}"/>
                                    
                                    <!-- Clear Log Button -->
                                    <Button x:Name="ClearLogButton"
                                           Content="🗑️ Clear"
                                           Background="#E74C3C"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Height="35"
                                           Padding="15,0"
                                           BorderThickness="0"
                                           Cursor="Hand"
                                           Click="ClearLogButton_Click"
                                           Style="{StaticResource ActionButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Logging Content -->
                        <Grid Grid.Row="1" Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Statistics Row -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Total Entries -->
                                <Border Grid.Column="0" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="📊 Total" FontSize="11" FontWeight="Bold" 
                                                  Foreground="#2C3E50" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ApplicationLogger.TotalEntries}" FontSize="18" FontWeight="Bold" 
                                                  Foreground="#3498DB" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Error Count -->
                                <Border Grid.Column="1" Background="#FADBD8" CornerRadius="5" Padding="10" Margin="5,0">
                                    <StackPanel>
                                        <TextBlock Text="❌ Errors" FontSize="11" FontWeight="Bold" 
                                                  Foreground="#C0392B" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ApplicationLogger.ErrorCount}" FontSize="18" FontWeight="Bold" 
                                                  Foreground="#E74C3C" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Button Clicks -->
                                <Border Grid.Column="2" Background="#D5F4E6" CornerRadius="5" Padding="10" Margin="5,0">
                                    <StackPanel>
                                        <TextBlock Text="🖱️ Clicks" FontSize="11" FontWeight="Bold" 
                                                  Foreground="#196F3D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ApplicationLogger.ButtonClickCount}" FontSize="18" FontWeight="Bold" 
                                                  Foreground="#27AE60" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Actions -->
                                <Border Grid.Column="3" Background="#FEF9E7" CornerRadius="5" Padding="10" Margin="5,0">
                                    <StackPanel>
                                        <TextBlock Text="⚡ Actions" FontSize="11" FontWeight="Bold" 
                                                  Foreground="#B7950B" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ApplicationLogger.ActionCount}" FontSize="18" FontWeight="Bold" 
                                                  Foreground="#F1C40F" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Status -->
                                <Border Grid.Column="4" Background="{Binding LoggingStatusBackground}" CornerRadius="5" Padding="10" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Status" FontSize="11" FontWeight="Bold" 
                                                  Foreground="#2C3E50" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LoggingStatusText}" FontSize="12" FontWeight="Bold" 
                                                  Foreground="{Binding LoggingStatusColor}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            
                            <!-- Log Entries List -->
                            <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="5" BorderBrush="#D5DBDB" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Filter Row -->
                                    <Border Grid.Row="0" Background="#F8F9FA" Padding="10" 
                                           BorderBrush="#D5DBDB" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="Filter:" FontWeight="Bold" 
                                                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="All" Tag="All" Click="FilterButton_Click" 
                                                       Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                                <Button Content="Errors" Tag="Error" Click="FilterButton_Click" 
                                                       Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                                <Button Content="Actions" Tag="Action" Click="FilterButton_Click" 
                                                       Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                                <Button Content="Clicks" Tag="ButtonClick" Click="FilterButton_Click" 
                                                       Style="{StaticResource FilterButtonStyle}" Margin="0,0,5,0"/>
                                                <Button Content="System" Tag="SystemInfo" Click="FilterButton_Click" 
                                                       Style="{StaticResource FilterButtonStyle}"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="2" Text="{Binding FilteredEntriesText}" 
                                                      FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Actual Log List -->
                                    <ListBox Grid.Row="1" x:Name="LogEntriesListBox"
                                            ItemsSource="{Binding FilteredLogEntries}"
                                            SelectedItem="{Binding SelectedLogEntry}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding BackgroundColor}" 
                                                       BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" 
                                                       Padding="10,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Column="0" Text="{Binding FormattedTimestamp}" 
                                                                  FontFamily="Consolas" FontSize="10" 
                                                                  Foreground="#7F8C8D" VerticalAlignment="Top" 
                                                                  Margin="0,0,10,0" Width="70"/>
                                                        
                                                        <TextBlock Grid.Column="1" Text="{Binding TypeIcon}" 
                                                                  FontSize="12" VerticalAlignment="Top" 
                                                                  Margin="0,0,8,0"/>
                                                        
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding DisplayText}" 
                                                                      FontSize="12" TextWrapping="Wrap"
                                                                      Foreground="{Binding LevelColor}"/>
                                                            <TextBlock Text="{Binding Details}" 
                                                                      FontSize="10" FontFamily="Consolas"
                                                                      Foreground="#7F8C8D" TextWrapping="Wrap"
                                                                      Margin="0,2,0,0"
                                                                      Visibility="{Binding Details, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                        
                                                        <TextBlock Grid.Column="3" Text="{Binding Source}" 
                                                                  FontSize="10" FontWeight="Bold" 
                                                                  Foreground="#95A5A6" VerticalAlignment="Top" 
                                                                  Margin="10,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                            
                            <!-- Log Directory Info -->
                            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="📁 Log Directory:" FontWeight="Bold" 
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding LogDirectory}" 
                                              FontFamily="Consolas" FontSize="11" 
                                              VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    
                                    <Button Grid.Column="2" Content="📂 Open Folder" 
                                           Click="OpenLogFolderButton_Click"
                                           Style="{StaticResource FilterButtonStyle}"
                                           Height="25" FontSize="10"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>